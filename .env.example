# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Hindsight API auth (REQUIRED) ----------------------------------------------------------------
# Hindsight is UNAUTHENTICATED by default; this stack enforces a bearer token on every API call.
# Generate: openssl rand -hex 32
# Set the SAME value on the Hermes side (the hindsight memory-provider api key). See SECURITY.md.
HINDSIGHT_API_KEY=

# Network isolation (recommended): bind the API to ONE interface instead of all of them — e.g. your
# Tailscale/WireGuard IP — so :8888 isn't served on the open LAN. Leave unset for 0.0.0.0 (all ifaces).
#BIND_ADDR=100.64.0.2

# Control-plane UI access key — only needed if you publish :9999 in docker-compose.yml.
#HINDSIGHT_CP_ACCESS_KEY=

# --- Postgres (Hindsight's own vchord-backed DB, isolated from your other databases) ---
# Keep this URL-safe: it is embedded in a postgresql:// connection URL, so avoid @ : / # ? & % characters.
POSTGRES_PASSWORD=change-me-url-safe

# --- Embedding endpoint: your OpenAI-compatible /v1/embeddings serving Qwen3-Embedding-8B (4096-dim) ---
# INCLUDE the /v1 suffix here.
EMBEDDINGS_BASE_URL=https://llm-gen.example.com/v1
EMBEDDINGS_MODEL=qwen3-embedding-8b
EMBEDDINGS_API_KEY=sk-noauth          # llama-swap ignores it, but it must be non-empty

# --- Chat LLM endpoint: your OpenAI-compatible chat model (used for fact extraction/reflection) ---
# HOST ROOT ONLY — do NOT include /v1. The no-think proxy appends the request path itself;
# adding /v1 here causes a doubled /v1/v1/... 404.
LLM_UPSTREAM_BASE_URL=https://llm.example.com
LLM_MODEL=qwen3.6-35b-a3b

# --- Image pins. Bump deliberately after reviewing release notes. For best integrity pin a digest
# (e.g. ...hindsight@sha256:<digest>), found via: docker buildx imagetools inspect <ref> ---
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:0.8.3
VCHORD_IMAGE=ghcr.io/tensorchord/vchord-postgres:pg17-v1.1.1
